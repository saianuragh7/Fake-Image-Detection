# Optional: backend URL the dev server should proxy /api requests to.
# Defaults to http://localhost:8080 if unset.
VITE_API_PROXY_TARGET=http://localhost:8080

# Defaults to auto: use the in-browser mock API unless VITE_API_BASE_URL is configured.
# Set false when a live backend is available behind /api or your hosting proxy.
VITE_USE_MOCK_API=auto
VITE_API_BASE_URL=
